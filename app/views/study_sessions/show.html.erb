<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold">Study Session</h1>
    <a href="https://dos.ny.gov/system/files/documents/2024/05/notary.pdf" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:text-blue-700 underline text-sm">📖 View PDF <span class="sr-only">(opens in new tab)</span></a>
  </div>
  
  <div class="mb-8">
    <div class="bg-gray-100 rounded-lg p-4 mb-6">
      <div class="flex justify-between items-center mb-2">
        <span class="text-sm font-semibold">Progress:</span>
        <span class="text-sm"><%= @progress[:current] %> / <%= @progress[:total] %> cards</span>
      </div>
      <div class="w-full bg-gray-300 rounded-full h-2.5" role="progressbar" aria-valuenow="<%= @progress[:percentage] %>" aria-valuemin="0" aria-valuemax="100" aria-label="Study session progress: <%= @progress[:current] %> of <%= @progress[:total] %> cards completed">
        <div class="bg-blue-600 h-2.5 rounded-full" style="width: <%= @progress[:percentage] %>%"></div>
      </div>
    </div>

    <% if @current_card %>
      <%= render FlashCardComponent.new(card: @current_card, study_session: @study_session) %>
    <% else %>
      <div class="bg-white shadow-lg rounded-lg p-8 text-center">
        <h2 class="text-2xl font-bold mb-4">Study Session Complete! 🎉</h2>
        <p class="text-lg mb-4">You studied <%= @study_session.cards_studied %> cards</p>
        <p class="text-lg mb-6">Accuracy: <%= @study_session.cards_studied > 0 ? ((@study_session.correct_count.to_f / @study_session.cards_studied) * 100).round(1) : 0 %>%</p>
        <%= link_to "Back to Home", root_path, class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
        <%= link_to "View Dashboard", dashboard_path, class: "bg-green-500 hover:bg-green-700 text-white font-bold py-2 px-4 rounded ml-2" %>
      </div>
    <% end %>
  </div>
  
  <div class="text-center mt-8">
    <%= link_to "← Back to Home", root_path, class: "text-blue-500 hover:text-blue-700" %>
  </div>
</div>
